              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "http://{{url}}:1026/v2/subscriptions",
              "protocol": "http",
              "host": [
                "{{url}}"
              ],
              "port": "1026",
              "path": [
                "v2",
                "subscriptions"
              ]
            },
            "description": "O Orion passará a notificar o STH sempre que humidity mudar."
          },
          "response": []
