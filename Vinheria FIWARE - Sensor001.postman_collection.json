              },
              {
                "key": "fiware-servicepath",
                "value": "/"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"comando\": {\n    \"type\": \"command\",\n    \"value\": \"sensor001@temp_alta|\"\n  }\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
