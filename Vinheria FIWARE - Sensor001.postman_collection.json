    {
      "name": "PASSO 7 — Comandos de Anomalia (ESP32)",
      "item": [
        {
          "name": "7.1 Temperatura Alta — LED vermelho, 3 bipes 1500Hz",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "fiware-service",
                "value": "smart"
              },
              {
                "key": "fiware-servicepath",
                "value": "/"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"comando\": { \"type\": \"command\", \"value\": \"sensor001@temp_alta|\" }\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "http://{{url}}:1026/v2/entities/urn:ngsi-ld:Sensor:001/attrs",
