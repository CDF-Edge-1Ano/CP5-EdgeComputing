    {
      "name": "PASSO 2 — Provisionamento do Serviço",
      "item": [
        {
          "name": "2.1 Criar Service Group MQTT",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "fiware-service",
                "value": "smart"
              },
              {
                "key": "fiware-servicepath",
                "value": "/"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"services\": [\n    {\n      \"apikey\": \"TEF\",\n      \"cbroker\": \"http://{{url}}:1026\",\n      \"entity_type\": \"Thing\",\n      \"resource\": \"\"\n    }\n  ]\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "http://{{url}}:4041/iot/services",
              "protocol": "http",
              "host": [
                "{{url}}"
              ],
              "port": "4041",
              "path": [
                "iot",
                "services"
              ]
            },
            "description": "Resposta esperada: 201 Created."
          },
          "response": []
        },
        {
          "name": "2.2 Verificar Service Group",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "fiware-service",
                "value": "smart"
              },
              {
                "key": "fiware-servicepath",
                "value": "/"
              }
            ],
            "url": {
              "raw": "http://{{url}}:4041/iot/services",
              "protocol": "http",
              "host": [
                "{{url}}"
              ],
              "port": "4041",
              "path": [
                "iot",
                "services"
              ]
            }
          },
          "response": []
        },
        {
          "name": "2.3 Deletar Service Group (reset)",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "fiware-service",
                "value": "smart"
              },
              {
                "key": "fiware-servicepath",
                "value": "/"
              }
            ],
            "url": {
              "raw": "http://{{url}}:4041/iot/services/?resource=&apikey=TEF",
              "protocol": "http",
              "host": [
                "{{url}}"
              ],
              "port": "4041",
              "path": [
                "iot",
                "services",
                ""
              ],
              "query": [
                {
                  "key": "resource",
                  "value": ""
                },
                {
                  "key": "apikey",
                  "value": "TEF"
                }
              ]
            }
          },
          "response": []
        }
      ],
      "description": "Registra o grupo de serviço MQTT com apikey TEF. Execute uma vez. Se retornar 409, o serviço já existe — pule para o Passo 3."
    },
    {
      "name": "PASSO 3 — Provisionamento do Dispositivo",
      "item": [
        {
          "name": "3.1 Provisionar Sensor001",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "fiware-service",
                "value": "smart"
              },
              {
                "key": "fiware-servicepath",
                "value": "/"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"devices\": [\n    {\n      \"device_id\":   \"sensor001\",\n      \"entity_name\": \"urn:ngsi-ld:Sensor:001\",\n      \"entity_type\": \"Sensor\",\n      \"protocol\":    \"PDI-IoTA-UltraLight\",\n      \"transport\":   \"MQTT\",\n      \"commands\": [\n        { \"name\": \"comando\", \"type\": \"command\" }\n      ],\n      \"attributes\": [\n        { \"object_id\": \"l\", \"name\": \"luminosity\",  \"type\": \"Integer\" },\n        { \"object_id\": \"t\", \"name\": \"temperature\", \"type\": \"Float\"   },\n        { \"object_id\": \"h\", \"name\": \"humidity\",    \"type\": \"Float\"   }\n      ]\n    }\n  ]\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "http://{{url}}:4041/iot/devices",
              "protocol": "http",
              "host": [
                "{{url}}"
              ],
              "port": "4041",
              "path": [
                "iot",
                "devices"
              ]
            },
            "description": "Resposta esperada: 201 Created."
          },
          "response": []
        },
        {
          "name": "3.2 Listar Dispositivos",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "fiware-service",
                "value": "smart"
              },
              {
                "key": "fiware-servicepath",
                "value": "/"
              }
            ],
            "url": {
              "raw": "http://{{url}}:4041/iot/devices",
              "protocol": "http",
              "host": [
                "{{url}}"
              ],
              "port": "4041",
              "path": [
                "iot",
                "devices"
              ]
            }
          },
          "response": []
        },
        {
          "name": "3.3 Deletar Sensor001 no IoT Agent (reset)",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "fiware-service",
                "value": "smart"
              },
              {
                "key": "fiware-servicepath",
                "value": "/"
              }
            ],
            "url": {
              "raw": "http://{{url}}:4041/iot/devices/sensor001",
              "protocol": "http",
              "host": [
                "{{url}}"
              ],
              "port": "4041",
              "path": [
                "iot",
                "devices",
                "sensor001"
              ]
            }
          },
          "response": []
        },
        {
          "name": "3.4 Deletar Sensor001 no Orion (reset)",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "fiware-service",
                "value": "smart"
              },
              {
                "key": "fiware-servicepath",
                "value": "/"
              }
            ],
            "url": {
              "raw": "http://{{url}}:1026/v2/entities/urn:ngsi-ld:Sensor:001",
              "protocol": "http",
              "host": [
                "{{url}}"
              ],
              "port": "1026",
              "path": [
                "v2",
                "entities",
                "urn:ngsi-ld:Sensor:001"
              ]
            }
          },
          "response": []
        }
      ],
      "description": "Registra o sensor001 com luminosity, temperature e humidity. Execute uma vez."
