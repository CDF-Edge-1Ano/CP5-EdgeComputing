        {
          "name": "4.4 Verificar Subscrições Ativas",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "fiware-service",
                "value": "smart"
              },
              {
                "key": "fiware-servicepath",
                "value": "/"
              }
            ],
            "url": {
              "raw": "http://{{url}}:1026/v2/subscriptions",
              "protocol": "http",
              "host": [
                "{{url}}"
              ],
              "port": "1026",
              "path": [
                "v2",
                "subscriptions"
              ]
            },
            "description": "Lista todas as subscrições. Devem aparecer as 3 criadas acima."
          },
          "response": []
        }
      ],
      "description": "Cria as subscrições para que o Orion notifique o STH-Comet a cada mudança de valor. Execute uma vez para cada atributo. Resposta esperada: 201 Created."
