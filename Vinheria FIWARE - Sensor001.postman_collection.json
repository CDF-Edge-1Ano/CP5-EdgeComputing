              "raw": "{\n  \"description\": \"Notifica STH-Comet sobre mudanças de luminosidade\",\n  \"subject\": {\n    \"entities\": [{ \"id\": \"urn:ngsi-ld:Sensor:001\", \"type\": \"Sensor\" }],\n    \"condition\": { \"attrs\": [\"luminosity\"] }\n  },\n  \"notification\": {\n    \"http\": { \"url\": \"http://fiware-sth-comet:8666/notify\" },\n    \"attrs\": [\"luminosity\"],\n    \"attrsFormat\": \"legacy\"\n  }\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
